# ─────────────────────────────────────────────────────────────────────────────
# Prism Campaigns — Environment Configuration
# Copy this file to .env and fill in your values.
# NEVER commit .env to version control.
# ─────────────────────────────────────────────────────────────────────────────

# Environment
ENVIRONMENT=development

# ─── PostgreSQL ───────────────────────────────────────────────────────────────
POSTGRES_USER=prism
POSTGRES_PASSWORD=change_me_strong_password
POSTGRES_DB=prism_campaigns

# ─── Redis ────────────────────────────────────────────────────────────────────
REDIS_PASSWORD=change_me_redis_password

# ─── JWT Auth ─────────────────────────────────────────────────────────────────
# Generate with: openssl rand -hex 32
SECRET_KEY=change_this_in_production_minimum_32_chars_long
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60
REFRESH_TOKEN_EXPIRE_DAYS=7

# ─── MinIO ────────────────────────────────────────────────────────────────────
MINIO_ROOT_USER=prism_minio_admin
MINIO_ROOT_PASSWORD=change_me_minio_password
MINIO_BUCKET=prism-creatives

# ─── Frontend ─────────────────────────────────────────────────────────────────
NEXT_PUBLIC_API_URL=http://localhost:8000
NEXTAUTH_URL=http://localhost:3000
NEXTAUTH_SECRET=change_this_nextauth_secret_32_chars_min

# ─── CORS ─────────────────────────────────────────────────────────────────────
ALLOWED_ORIGINS=http://localhost:3000,http://localhost

# ─── First Super Admin ────────────────────────────────────────────────────────
FIRST_SUPERUSER_EMAIL=admin@prism.local
FIRST_SUPERUSER_PASSWORD=Admin@123456
FIRST_SUPERUSER_NAME=System Administrator
